      <scale>
        <kf t="0.0" v="2.8,2.8" e="cubicBezier 0.37 0 0.63 1"/>
        <kf t="0.5" v="3.5,3.5" e="cubicBezier 0.37 0 0.63 1"/>
        <kf t="1.0" v="2.8,2.8"/>
      </scale>
      <rotation>
        <kf t="0.0" v="0"/>
        <kf t="1.0" v="40"/>
      </rotation>
      <opacity value="0.5"/>
    </transform>
    <fillColor value="#ff0a84ff"/>
    <property name="size" type="vec2" value="150,150"/>
    <effect id="com.alightcreative.effects.gaussianblur" locallyApplied="true">
      <property name="strength" type="float" value="2.0"/>
    </effect>
  </shape>
  <!-- second warm glow for depth -->
