<!-- Nimbus — keynote-style product film (Apple/Google language). 1080x1920, 14s, 60fps.
     Techniques: RSVP word flashes (single fixed spot), staged one-idea builds, layered
     move+scale+blur transforms, cinematic spring easing. kf t = 0..1 of each layer's life.

     LAYOUT TABLE (no two simultaneously-visible layers share a y-band):
       Backdrop/glow: full canvas, opacity <=0.6, never competes with text.
       RSVP words (S-A) : ALL at y=960, but each at a DIFFERENT time slice -> no overlap.
       Headline (S-B)   : line1 y=852, line2 y=968, sub y=1120  (bands 116/152 apart).
       Feature rows (S-C): rowA y=724, rowB y=904, rowC y=1084  (180 apart, no overlap).
       CTA (S-D)        : pill y=968, label y=968(on pill), url y=1108.
     Fonts: Poppins (all weights 100-900, verified in AM font_catalog.json). -->
<scene title="Nimbus SaaS Reveal" width="1080" height="1920" exportWidth="1080" exportHeight="1920"
       precompose="dynamicResolution" bgcolor="#ff05060b" totalTime="14000" fps="60"
       am="com.alightcreative.motion/5.0.273" amplatform="android" retime="freeze">

  <!-- ================= BACKDROP (bottom z) ================= -->
  <shape id="300001" label="bg" startTime="0" endTime="14000" s=".rect" fillType="gradient">
