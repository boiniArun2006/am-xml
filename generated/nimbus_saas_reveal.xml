      <location>
        <kf t="0.0" v="380,720,0" e="cubicBezier 0.45 0 0.55 1"/>
        <kf t="0.5" v="720,1140,0" e="cubicBezier 0.45 0 0.55 1"/>
        <kf t="1.0" v="380,720,0"/>
